<nav class="text-sm text-gray-600 mb-4 flex items-center space-x-1">
  <% breadcrumb.forEach((folder, index) => { %>
    <a href="/api/users/drive/<%= folder.id %>" class="hover:underline">
      <%= folder.name %>
    </a>

    <% if (index < breadcrumb.length - 1) { %>
      <span>></span>
    <% } %>
  <% }) %>
</nav>