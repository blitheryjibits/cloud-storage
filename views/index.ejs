<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Microcloud</title>
    <link href="/output.css" rel="stylesheet" />
  </head>
  <body
    class="bg-gradient-to-br from-indigo-600 to-purple-600 min-h-screen flex items-center justify-center text-white"
  >
    <div class="text-center px-6 max-w-xl">
      <h1 class="text-4xl font-bold mb-4">Welcome to Microcloud</h1>
      <p class="text-lg mb-6">
        Your personal cloud storage solution. Upload, organize, and share files
        with ease.
      </p>

      <div class="flex justify-center space-x-4">
        <a
          href="/api/auth/login"
          class="bg-white text-indigo-600 font-semibold px-6 py-2 rounded-md hover:bg-gray-100 transition"
        >
          Login
        </a>
        <a
          href="/api/auth/register"
          class="bg-white text-purple-600 font-semibold px-6 py-2 rounded-md hover:bg-gray-100 transition"
        >
          Register
        </a>
      </div>

      <!-- Guest Login -->
      <form action="/api/auth/login" method="POST" class="mt-6">
        <input type="hidden" name="username" value="guest" />
        <input type="hidden" name="password" value="guest" />

        <button
          type="submit"
          class="bg-gray-700 text-white py-2 px-4 rounded-md hover:bg-gray-800 hover:cursor-pointer transition duration-200"
        >
          Continue as Guest
        </button>
      </form>

      <div class="mt-10 text-sm text-gray-200">
        <p>Secure. Fast. Built for you.</p>
      </div>
    </div>
  </body>
</html>
